import matplotlib.pyplot as plt

categories = ["Rent", "Food", "Transport", "Entertainment", "Savings"]
amounts = [4000, 2800, 1000, 500, 2500]

plt.bar(categories, amounts, color=["blue", "green", "orange", "purple", "red"])

plt.title(" My Monthly Expenses Breakdown")
plt.xlabel("Categories")
plt.ylabel("Amount (₹)")

for i in range(len(amounts)):
    plt.text(i, amounts[i] + 200, str(amounts[i]), ha='center')

plt.show()

import matplotlib.pyplot as plt

categories = ["Rent", "Food", "Transport", "Entertainment", "Savings"]
amounts = [4000, 2800, 1000, 500, 2500]

plt.pie(
    amounts,
    labels=categories,
    autopct='%1.1f%%',
    colors=["blue", "green", "orange", "purple", "red"],
    startangle=90
)

plt.axis('equal')

plt.title("Monthly Expenses Breakdown (Pie Chart)")

plt.show()

import matplotlib.pyplot as plt

categories = ["Rent", "Food", "Transport", "Entertainment", "Savings"]
amounts = [4000, 2800, 1000, 500, 2500]

plt.plot(categories, amounts, marker='o', linestyle='-', color='blue')

plt.title("My Monthly Expenses Breakdown")
plt.xlabel("Categories")
plt.ylabel("Amount (₹)")

for i in range(len(amounts)):
    plt.text(i, amounts[i] + 200, str(amounts[i]), ha='center')

plt.grid(True)
plt.show()

import matplotlib.pyplot as plt

categories = ["Rent", "Food", "Transport", "Entertainment", "Savings"]
